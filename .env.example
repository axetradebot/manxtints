# Meta Pixel + Conversions API (CAPI)
# Public pixel id — safe to expose to the browser
NEXT_PUBLIC_META_PIXEL_ID=
# Server-only CAPI access token (System User token from Events Manager). Keep secret.
META_CAPI_ACCESS_TOKEN=
# Dataset id for the Conversions API — same value as the pixel id
META_DATASET_ID=
# Optional: route server events to Events Manager > Test events for verification.
# Set to a TEST code from the Test events tab; leave UNSET in production.
META_TEST_EVENT_CODE=
